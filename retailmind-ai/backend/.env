# RetailMind AI - Backend Environment Configuration
# Copy this to .env and fill in your API keys

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key
JWT_SECRET_KEY=retailmind-super-secret-jwt-key-2024

# Database (leave empty to use default SQLite path)
DATABASE_URL=

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=retailmind-flask-secret-2024
